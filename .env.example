# ─────────────────────────────────────────────
# Medexa Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit a populated .env to version control.
# ─────────────────────────────────────────────

# ── General ──────────────────────────────────
# Directory containing the JSON rule files (relative to the process cwd).
MEDEXA_CONFIG_DIR=config

# How long (seconds) before the same CPT suggestion re-appears.
MEDEXA_SUGGESTION_COOLDOWN_SECONDS=120

# Hard cap on session length (minutes). Sessions exceeding this auto-end.
MEDEXA_MAX_SESSION_DURATION_MINUTES=240

# ── API ───────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# Use * only during local development; set exact frontend URL in staging/production.
MEDEXA_CORS_ALLOW_ORIGINS=http://localhost:3000

# ── Logging (Phase 5) ─────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
MEDEXA_LOG_LEVEL=INFO

# ── Storage (Phase 4) ─────────────────────────
# Set to true when you have an AWS account and have run dynamodb_setup.py.
# Leave false for local development (uses in-memory store, no AWS needed).
MEDEXA_USE_DYNAMODB=false

# Name of the DynamoDB table (created by medexa.aws.dynamodb_setup).
MEDEXA_DYNAMODB_TABLE_NAME=medexa-sessions

# AWS region where the DynamoDB table lives.
MEDEXA_AWS_REGION=us-east-1

# ── AWS Credentials ───────────────────────────
# For local testing with DynamoDB, configure via the AWS CLI (`aws configure`)
# or set these variables directly. In Lambda these come from the IAM execution role.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
