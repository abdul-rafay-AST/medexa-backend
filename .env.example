MEDEXA_CONFIG_DIR=config
MEDEXA_CORS_ALLOW_ORIGINS=*
MEDEXA_LOG_LEVEL=INFO
MEDEXA_USE_DYNAMODB=false
MEDEXA_DYNAMODB_TABLE_NAME=medexa-sessions
MEDEXA_AWS_REGION=us-east-2
MEDEXA_AWS_ENVIRONMENT=staging
MEDEXA_S3_BUCKET=
MEDEXA_TRANSCRIBE_S3_BUCKET=
MEDEXA_CONFIG_SOURCE=local

# --- AWS Bedrock (Path B live assistant + Path C SOAP/summary) ---
# Bedrock uses standard AWS credentials (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY)
# or an IAM role. Set your region to one where Bedrock is enabled.
MEDEXA_PATH_B_ENABLED=true
MEDEXA_PATH_B_PROVIDER=bedrock
MEDEXA_PATH_B_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
MEDEXA_PATH_B_TRANSCRIPT_WINDOW_MINUTES=10
MEDEXA_PATH_B_TRANSCRIPT_MAX_CHUNKS=24

# Path A = rules; Path C finalize docs = Bedrock
MEDEXA_CLINICAL_ANALYZER=rules
MEDEXA_SOAP_GENERATOR=bedrock
MEDEXA_SUMMARY_GENERATOR=bedrock
MEDEXA_PATH_C_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
MEDEXA_BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# --- Deepgram (ambient STT + native speaker diarization) ---
# Put your real key ONLY in local .env or HF Space secrets — never commit it.
MEDEXA_TRANSCRIPTION_PROVIDER=deepgram
MEDEXA_DEEPGRAM_API_KEY=
MEDEXA_DEEPGRAM_BASE_URL=https://api.deepgram.com
MEDEXA_DEEPGRAM_MODEL=nova-3-medical
MEDEXA_DEEPGRAM_DIARIZE_MODEL=
MEDEXA_DEEPGRAM_LANGUAGE=en-US

# --- Groq (optional fallback only — not used when Bedrock + Deepgram are set) ---
MEDEXA_GROQ_API_KEY=
MEDEXA_GROQ_BASE_URL=https://api.groq.com/openai/v1
MEDEXA_GROQ_PATH_B_MODEL_ID=llama-3.1-8b-instant
MEDEXA_GROQ_PATH_C_MODEL_ID=llama-3.3-70b-versatile
MEDEXA_GROQ_WHISPER_MODEL_ID=whisper-large-v3-turbo
