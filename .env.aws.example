# ─────────────────────────────────────────────
# Medexa AWS Environment (copy to .env)
# Use after: pip install -e ".[aws]" && python scripts/aws_bootstrap.py
# ─────────────────────────────────────────────

MEDEXA_AWS_REGION=us-east-2
MEDEXA_AWS_ENVIRONMENT=staging

# DynamoDB — one table for ALL billing regions (US, SA, UAE)
MEDEXA_USE_DYNAMODB=true
MEDEXA_DYNAMODB_TABLE_NAME=medexa-sessions

# S3 — existing Medexa bucket in us-east-2
MEDEXA_S3_BUCKET=medexa-storage
MEDEXA_TRANSCRIBE_S3_BUCKET=medexa-storage

# Rule packs ship in the container image (config/)
MEDEXA_CONFIG_SOURCE=local
MEDEXA_CONFIG_DIR=config

# Ambient STT — choose one:
#   deepgram       = low latency (recommended for live ambient UX)
#   aws_transcribe = Amazon Transcribe standard (AWS-native, higher latency)
MEDEXA_TRANSCRIPTION_PROVIDER=aws_transcribe
MEDEXA_TRANSCRIBE_ENABLE_SPEAKER_LABELS=true
MEDEXA_TRANSCRIBE_MAX_SPEAKERS=2
MEDEXA_TRANSCRIBE_POLL_TIMEOUT_SECONDS=120
MEDEXA_TRANSCRIBE_LANGUAGE_CODE=en-US
# Optional Deepgram if you switch provider back:
# MEDEXA_TRANSCRIPTION_PROVIDER=deepgram
# MEDEXA_DEEPGRAM_MODEL=nova-3-medical
# MEDEXA_DEEPGRAM_API_KEY injected from Secrets Manager in App Runner
# Do NOT put AWS access keys on App Runner — use the instance IAM role.

# Path B/C — Bedrock only (no Groq failover on AWS)
MEDEXA_PATH_B_ENABLED=true
MEDEXA_PATH_B_PROVIDER=bedrock
MEDEXA_PATH_B_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
MEDEXA_SOAP_GENERATOR=bedrock
MEDEXA_SUMMARY_GENERATOR=bedrock
MEDEXA_PATH_C_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
MEDEXA_BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

MEDEXA_CORS_ALLOW_ORIGINS=https://YOUR-APP.vercel.app,http://localhost:3000

# Local laptop only (App Runner uses IAM role instead):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
