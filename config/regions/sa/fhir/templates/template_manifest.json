      "profile": "http://nphies.sa/fhir/ksa/nphies-fs/StructureDefinition/professional-claim|1.0.0",
      "use": "claim",
      "default_sub_type": "op"
    },
    "priorauth_request": {
      "file": "priorauth-request.template.json",
      "message_event": "priorauth-request",
