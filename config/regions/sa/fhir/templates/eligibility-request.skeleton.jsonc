          }
        ],
        "active": true,
        "type": [
          {
            "coding": [
              {
                "system": "http://nphies.sa/terminology/CodeSystem/organization-type",
                "code": "prov", // STATIC
                "display": "Healthcare Provider"
              }
            ]
          }
        ],
        "name": "", // [CLINIC] clinic legal name. REJECT if empty live.
        "address": [
          {
            "use": "work",
            "text": "", // [CLINIC] soft
            "city": "", // [CLINIC] soft
            "country": "Saudi Arabia" // STATIC
          }
        ]
