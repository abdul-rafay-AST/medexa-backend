          ]
        },
        "identifier": [
          {
            "system": "https://medexa.internal/identifiers/member-id",
            "value": "" // [MEDEXA] state.member_id. REJECT if empty live.
          }
        ],
        "status": "active", // STATIC
        "type": {
          "coding": [
            {
              "system": "http://nphies.sa/terminology/CodeSystem/coverage-type",
              "code": "EHCPOL", // STATIC default extended healthcare
              "display": "extended healthcare"
            }
          ]
        },
        "subscriber": {
          "reference": "" // [RUNTIME] usually Patient/{id} when relationship=self
        },
        "beneficiary": {
          "reference": "" // [RUNTIME] Patient/{id}
        },
        "relationship": {
          "coding": [
            {
              "system": "http://terminology.hl7.org/CodeSystem/subscriber-relationship",
              "code": "" // [INTAKE/EHR or PAYER_DIR] self|spouse|child. REJECT if empty live.
            }
          ]
        },
        "payor": [
          {
            "reference": "" // [RUNTIME] Organization/insurer
          }
        ],
        "class": [
          {
            "type": {
              "coding": [
                {
                  "system": "http://terminology.hl7.org/CodeSystem/coverage-class",
                  "code": "plan" // STATIC
                }
              ]
            },
            "value": "", // [PAYER_DIR / eligibility response] plan code. Often REJECT if empty.
            "name": "" // [PAYER_DIR] plan display name
          }
        ],
        "network": "" // [PAYER_DIR / eligibility response] network id. Often REJECT if empty.
      }
    },
    {
      "fullUrl": "http://yourclinic.com/Organization/PR-123",
      "resource": {
        "resourceType": "Organization",
        "id": "", // [RUNTIME]
        "meta": {
