{
  "source_name": "Medexa Internal - NPHIES Claim Field Map",
  "version": "1.0.0",
  "service_code_system": "http://nphies.sa/terminology/CodeSystem/services",
  "diagnosis_code_system": "http://hl7.org/fhir/sid/icd-10-am",
  "mappings": [
    {"session_field": "payer_id", "fhir_path": "MessageHeader.destination.receiver.identifier.value"},
    {"session_field": "member_id", "fhir_path": "Coverage.identifier.value"},
    {"session_field": "pre_auth_reference", "fhir_path": "Claim.insurance.preAuthRef"},
    {"session_field": "episode_id", "fhir_path": "Claim.extension[extension-episode].valueIdentifier.value"},
    {"session_field": "eligibility_response_id", "fhir_path": "Claim.extension[extension-eligibility-response].valueReference.identifier.value"},
    {"billing_field": "line_items[].sbs_code", "fhir_path": "Claim.item.productOrService.coding.code"},
    {"billing_field": "line_items[].patient_invoice_id", "fhir_path": "Claim.item.extension[extension-patientInvoice].valueIdentifier.value"},
    {"billing_field": "line_items[].maternity", "fhir_path": "Claim.item.extension[extension-maternity].valueBoolean"},
    {"billing_field": "line_items[].is_package", "fhir_path": "Claim.item.extension[extension-package].valueBoolean"},
    {"clinical_field": "encounter_setting", "fhir_path": "Encounter.class.code", "allowed_values": ["AMB", "EMER", "HH", "VR"]}
  ]
}
